# App URL (used for OAuth redirects in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Lovable Cloud / Supabase ---
# Auto-injected when Lovable Cloud is enabled. Do not edit by hand.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- GitHub OAuth ---
# Create an OAuth App: https://github.com/settings/developers
# Authorization callback URL must be:
#   https://<your-supabase-project-ref>.supabase.co/auth/v1/callback
# In Lovable Cloud → Auth → Providers → GitHub, paste Client ID + Secret.
# Recommended scopes: read:user user:email repo read:org
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: shared secret for the future GitHub webhook receiver
GITHUB_WEBHOOK_SECRET=

# --- AI provider ---
# Provisioned automatically in Lovable Cloud, stays server-side.
LOVABLE_API_KEY=

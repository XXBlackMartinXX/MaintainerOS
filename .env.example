# MaintainerOS environment variables
#
# Your hosting provider may inject the SUPABASE_* and VITE_SUPABASE_* values
# automatically. You only need to set the GitHub and (optionally) AI gateway
# values.
#
# Never commit a real `.env`. This file documents the names and shapes only.

# --- App URL (used for OAuth redirects in production) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase (may be auto-injected by the hosting provider) ---
# Client-side (safe to expose, inlined into the browser bundle by Vite):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PUBLISHABLE_KEY=     # Accepted as a fallback for VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_PROJECT_ID=
# Server-side fallback names (also accepted at runtime):
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=          # Accepted as a fallback for SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=         # SERVER ONLY. Never exposed to the browser.

# --- GitHub OAuth (required for sign-in and sync) ---
# Create an OAuth App: https://github.com/settings/developers
# Authorization callback URL must be:
#   https://<your-supabase-project-ref>.supabase.co/auth/v1/callback
# Recommended scopes: read:user user:email repo read:org
# Configure in: Supabase Auth -> Providers -> GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: shared secret for a future GitHub webhook receiver
GITHUB_WEBHOOK_SECRET=

# --- Managed AI gateway (required for AI features) ---
# The current implementation expects `LOVABLE_API_KEY` as the server-side
# API key for the managed AI gateway. It is read server-side only and is
# never exposed to the browser.
LOVABLE_API_KEY=

# --- Feature toggles ---
# All of these are optional and detected automatically by `src/lib/env.ts`:
#   - GitHub OAuth        -> requires GITHUB_CLIENT_ID + GITHUB_CLIENT_SECRET
#   - AI features         -> requires LOVABLE_API_KEY
#   - GitHub write actions-> requires GitHub OAuth + `repo` scope at sign-in time
#   - Demo mode           -> always available; toggled in the browser only
